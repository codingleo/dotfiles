{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "lsp": true
}